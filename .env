# === App ===
APP_NAME=host_resource_ai_agent
APP_ENV=production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8082
SECRET_KEY=change-me-in-production

# === Database (MySQL on Server 1: 172.16.50.93) ===
DATABASE_URL=mysql+asyncmy://ai_bot:123@127.0.0.1:3306/host_resource_agent

# === Redis (on Server 1: 172.16.50.93) ===
REDIS_URL=redis://:123@127.0.0.1:6379/0
REDIS_DEDUP_TTL=300
REDIS_APPROVAL_TTL=3600
REDIS_EXEC_LOCK_TTL=600

# === Prometheus (on Server 1: 172.16.50.93, scrapes Server 2) ===
PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_TIMEOUT=30

# === SSH (Agent SSH vào Server 2: 172.16.50.147) ===
SSH_USER=devops
SSH_KEY_PATH=/home/devops/.ssh/id_rsa
SSH_TIMEOUT=30
SSH_COMMAND_TIMEOUT=60

# === LLM (Google Gemini) ===
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyAPpuGyQvsEu2Jy-WkJCdCLpMs9YSLKx9U
GEMINI_MODEL=gemini-2.0-flash
LLM_TIMEOUT=360
LLM_MAX_RETRIES=2

# === Worker ===
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL=2

# === Auth ===
AUTH_ENABLED=false
AUTH_TOKEN=operator-token-change-me
